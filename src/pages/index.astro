---
import "../styles/global.css";
const nombreAsilo = "Asilo de Indigentes San José";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{nombreAsilo}</title>
	</head>
	<body>
		<nav>
			<div style="display: flex; align-items: center; gap: 1rem;">
				<img src="/logo.png" alt="Logo" height="55" />
				<div style="line-height: 1.1;">
					<span
						style="font-weight: bold; color: var(--brand-color); font-size: 1rem; display: block;"
						>Asilo de Indigentes</span
					>
					<span
						style="font-weight: 900; color: var(--brand-dark); font-size: 1.2rem; letter-spacing: 1px;"
						>SAN JOSÉ</span
					>
				</div>
			</div>
			<div class="nav-links">
				<a href="#nosotros">Nosotros</a>
				<a
					href="#contacto"
					class="btn-primary"
					style="padding: 0.5rem 1.5rem; border: 2px solid var(--brand-color);"
					>Donar</a
				>
			</div>
		</nav>

		<header class="hero">
			<h1 style="font-size: 3rem; margin-bottom: 1rem;">
				Dignidad y Amor en la Vejez
			</h1>
			<p
				style="font-size: 1.3rem; max-width: 700px; margin: 0 auto 2rem auto; opacity: 0.9;"
			>
				Brindamos un hogar seguro y cuidado integral a nuestros adultos
				mayores en Quetzaltenango.
			</p>
			<a href="#nosotros" class="btn-primary">Conoce nuestra labor</a>
		</header>

		<section id="nosotros">
			<h2>Nuestra Identidad</h2>
			<div class="grid">
				<div class="card">
					<h3 style="color: var(--brand-color);">Misión</h3>
					<p>
						Brindar atención integral a adultos mayores en
						vulnerabilidad, asegurando alimentación, salud y
						vivienda digna, promoviendo la solidaridad como eje
						central.
					</p>
				</div>
				<div class="card">
					<h3 style="color: var(--brand-color);">Visión</h3>
					<p>
						Ser un referente regional en el cuidado integral,
						reconocido por la calidad humana y la capacidad de
						generar conciencia social sobre el valor de nuestros
						mayores.
					</p>
				</div>
			</div>

			<div class="card" style="margin-top: 2rem;">
				<h3 style="text-align: center;">Nuestros Valores Éticos</h3>
				<p
					style="text-align: center; color: var(--text-muted); max-width: 600px; margin: 0 auto 2rem auto;"
				>
					Principios que guían nuestro compromiso diario con la
					dignidad de nuestros mayores.
				</p>

				<ul class="valores-lista">
					<li>Solidaridad</li>
					<li>Respeto</li>
					<li>Transparencia</li>
					<li>Compromiso</li>
					<li>Empatía</li>
					<li>Inclusión</li>
				</ul>
			</div>
		</section>

		<section id="servicios" style="background-color: var(--white);">
			<h2>Servicios que Brindamos</h2>
			<div class="grid">
				<div class="service-item">
					<h4>🍎 Alimentación</h4>
					<p>
						Dieta balanceada y adaptada a necesidades nutricionales.
					</p>
				</div>
				<div class="service-item">
					<h4>⚕️ Atención Médica</h4>
					<p>Seguimiento personalizado y acompañamiento en citas.</p>
				</div>
				<div class="service-item">
					<h4>🎨 Recreación</h4>
					<p>
						Talleres cognitivos, áreas verdes y convivencia social.
					</p>
				</div>
				<div class="service-item">
					<h4>🏠 Vivienda Digna</h4>
					<p>Espacios seguros y adaptados en el corazón de Xela.</p>
				</div>
			</div>
		</section>

		<section id="ubicacion">
			<h2>¿Dónde estamos?</h2>
			<div class="card" style="text-align: center;">
				<p>
					📍 <strong
						>14 Avenida, Zona 3 (Frente a Emax), Quetzaltenango.</strong
					>
				</p>
				<p>
					Nuestra ubicación estratégica nos permite estar cerca de la
					comunidad para facilitar el voluntariado.
				</p>
			</div>
		</section>

		<section
			id="contacto"
			style="background-color: #fff; border-radius: 30px; margin-bottom: 4rem;"
		>
			<h2 style="margin-top: 0;">¿Cómo puedes ayudar?</h2>
			<p style="text-align: center; color: var(--text-muted);">
				Completa el formulario y nos pondremos en contacto contigo para
				coordinar tu apoyo.
			</p>

			<form
				name="contacto-asilo"
				method="POST"
				data-netlify="true"
				style="max-width: 600px; margin: 2rem auto 0 auto;"
			>
				<div style="margin-bottom: 1.5rem;">
					<label
						style="display: block; font-weight: bold; margin-bottom: 0.5rem;"
						>Nombre Completo</label
					>
					<input
						type="text"
						name="nombre"
						required
						style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 8px;"
					/>
				</div>
				<div style="margin-bottom: 1.5rem;">
					<label
						style="display: block; font-weight: bold; margin-bottom: 0.5rem;"
						>¿Cómo deseas colaborar?</label
					>
					<textarea
						name="mensaje"
						rows="4"
						style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 8px;"
						placeholder="Donaciones, voluntariado, víveres..."
					></textarea>
				</div>
				<button
					type="submit"
					class="btn-primary"
					style="background-color: var(--brand-color); color: white; border: none; width: 100%; cursor: pointer; font-size: 1.1rem;"
					>Enviar Mensaje</button
				>
			</form>
		</section>

		<footer class="site-footer">
			<div class="footer-content">
				<div class="footer-brand">
					<img
						src="/logo-asilo.png"
						alt="Logo San José"
						height="40"
					/>
					<p>Asilo de Indigentes San José</p>
				</div>

				<div class="footer-info">
					<h4>Ubicación</h4>
					<p>
						14 Avenida, Zona 3 (Frente a Emax)<br />Quetzaltenango,
						Guatemala.
					</p>
				</div>

				<div class="footer-project">
					<h4>Proyecto Académico</h4>
					<p>
						Desarrollado para el curso de Ética Profesional<br />7mo
						Semestre, Ingeniería en Sistemas.
					</p>
				</div>
			</div>

			<div class="footer-bottom">
				<p>
					&copy; 2026 Asilo de Indigentes San José. Todos los derechos
					reservados.
				</p>
			</div>
		</footer>
	</body>
</html>
